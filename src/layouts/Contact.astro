---
import "../styles/global.css";

const email = "andrewforcouncil2026@gmail.com";
const phone = "(343) 422-5096";

const socialButtons = [
    {
        name: "Instagram",
        href: "https://www.instagram.com/andrewforcouncil/",
        icon: "M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm4.2 3.2A4.8 4.8 0 1 1 7.2 12 4.8 4.8 0 0 1 12 7.2Zm0 2A2.8 2.8 0 1 0 14.8 12 2.8 2.8 0 0 0 12 9.2Zm5.05-3.35A1.15 1.15 0 1 1 15.9 7a1.15 1.15 0 0 1 1.15-1.15Z",
        accent: "hover:border-pink-500 hover:text-pink-600 focus-visible:border-pink-500 focus-visible:text-pink-600",
    },
    {
        name: "Facebook",
        href: "https://www.facebook.com/andrew4council/",
        icon: "M13.5 22v-9h3l.5-3h-3.5V8.1c0-.9.3-1.6 1.8-1.6H17V4a22 22 0 0 0-2.4-.2c-2.4 0-4.1 1.5-4.1 4.2v2H8v3h2.5v9h3Z",
        accent: "hover:border-blue-600 hover:text-blue-600 focus-visible:border-blue-600 focus-visible:text-blue-600",
    },
    {
        name: "TikTok",
        href: "https://www.tiktok.com/@andrew4council",
        icon: "M16.6 3c.4 1.9 1.1 3.1 3.4 3.5V10a8.1 8.1 0 0 1-3.4-.8v4.5a6.2 6.2 0 1 1-5.3-6.1v3.5a2.8 2.8 0 1 0 1.8 2.6V2h3.5v1Z",
        accent: "hover:border-slate-950 hover:text-slate-950 focus-visible:border-slate-950 focus-visible:text-slate-950",
    },
    {
        name: "YouTube",
        href: "https://www.youtube.com/@andrewforcouncil",
        icon: "M21.6 7.2a2.9 2.9 0 0 0-2-2C17.8 4.7 12 4.7 12 4.7s-5.8 0-7.6.5a2.9 2.9 0 0 0-2 2A30 30 0 0 0 2 12a30 30 0 0 0 .4 4.8 2.9 2.9 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.9 2.9 0 0 0 2-2A30 30 0 0 0 22 12a30 30 0 0 0-.4-4.8ZM10 15.5v-7l6 3.5-6 3.5Z",
        accent: "hover:border-red-600 hover:text-red-600 focus-visible:border-red-600 focus-visible:text-red-600",
    },
];
---

<main class="min-h-fit bg-almond text-slate-900">
    <section class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
        <!-- Main Message -->
        <div class="space-y-4">
            <h1
                class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
            >
                I would love to hear from you!
            </h1>

            <p class="text-lg leading-relaxed text-slate-700 sm:text-xl">
                Please reach out with any questions, comments, or concerns you
                may have about my campaign, or our district.
            </p>
        </div>

        <!-- Contact Details -->
        <div
            class="mt-8 space-y-2 text-lg font-medium text-slate-900 sm:text-xl"
        >
            <div>
                <a
                    href={`mailto:${email}`}
                    class="text-blue-700 underline hover:text-blue-900"
                >
                    {email}
                </a>
            </div>

            <div>
                <a
                    href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
                    class="hover:text-blue-700"
                >
                    {phone}
                </a>
            </div>
        </div>

        <!-- Social Media Section -->
        <div class="mt-12 border-t border-slate-200 pt-8">
            <h2 class="text-xl font-semibold text-slate-900">
                Keep up with the campaign on social media:
            </h2>

            <!-- Buttons -->
            <div class="mt-6 flex flex-wrap gap-3 sm:gap-4">
                {
                    socialButtons.map((btn) => (
                        <a
                            href={btn.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={btn.name}
                            title={btn.name}
                            class:list={[
                                "group inline-flex h-12 min-w-12 items-center justify-center overflow-hidden whitespace-nowrap rounded-full border border-slate-300 bg-white px-3 text-slate-700 shadow-sm transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-white hover:shadow-md focus:outline-none focus-visible:-translate-y-0.5 focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2",
                                btn.accent,
                            ]}
                        >
                            <svg
                                class="h-6 w-6 shrink-0"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path d={btn.icon} />
                            </svg>

                            <span
                                aria-hidden="true"
                                class="max-w-0 overflow-hidden opacity-0 transition-all duration-300 ease-out group-hover:ml-2 group-hover:max-w-28 group-hover:opacity-100 group-focus-visible:ml-2 group-focus-visible:max-w-28 group-focus-visible:opacity-100"
                            >
                                {btn.name}
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>
</main>
