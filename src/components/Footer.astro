---
import "../styles/global.css";

const year = new Date().getFullYear();
const link =
    "https://www.cityofkingston.ca/council-and-city-administration/elections/voters/";
const email = "andrewforcouncil2026@gmail.com";
const phone = "(343) 422-5096";
---

<footer class="mt-4 border-t border-gray-200 bg-section">
    <div class="mx-auto max-w-7xl px-4 py-10 md:px-6 md:py-12">
        <div class="grid gap-8 md:grid-cols-3 md:gap-10">
            <!-- Navigation -->
            <section class="min-w-0">
                <h3 class="mb-4 text-lg font-semibold text-almond">
                    Navigation
                </h3>

                <nav class="flex flex-col gap-2 text-almond">
                    <a href="/" class="transition hover:text-blue-200">
                        Home
                    </a>

                    <a href="/#platform" class="transition hover:text-blue-200">
                        Platform
                    </a>

                    <a href="/#about-me" class="transition hover:text-blue-200">
                        About
                    </a>

                    <a href="/contact" class="transition hover:text-blue-200">
                        Contact
                    </a>

                    <a
                        href="/get-involved"
                        class="transition hover:text-blue-200"
                    >
                        Get Involved
                    </a>
                </nav>
            </section>

            <!-- Contact -->
            <section class="min-w-0">
                <h3 class="mb-4 text-lg font-semibold text-almond">Contact</h3>

                <div class="space-y-2 text-almond">
                    <p>
                        Email: <a
                            href={`mailto:${email}`}
                            class="break-all underline hover:text-blue-200 sm:break-normal"
                        >
                            {email}
                        </a>
                    </p>
                    <p>
                        Phone: <a
                            href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
                            class="hover:text-blue-200"
                        >
                            {phone}
                        </a>
                    </p>
                </div>

                <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-almond">
                    <!-- Add social icons later -->
                    <a
                        href="https://www.instagram.com/andrewforcouncil/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline">Instagram</a
                    >
                    <a
                        href="https://www.facebook.com/andrew4council/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline">Facebook</a
                    >
                    <a
                        href="https://www.tiktok.com/@andrew4council"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline">TikTok</a
                    >
                    <a
                        href="https://www.youtube.com/@andrewforcouncil"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline">YouTube</a
                    >
                </div>
            </section>

            <!-- Voting -->
            <section class="min-w-0 rounded-2xl bg-header px-4 py-4">
                <h3 class="mb-4 text-lg font-semibold text-black">
                    How to Vote
                </h3>

                <p>
                    <b>Election Day</b> day is on <b> October 26</b>, with
                    advance voting taking place on <b>October 16 and 17</b>, and <b
                        >online voting</b
                    > being available from <b>October 14-26</b>. <a
                        href={link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-blue-700 underline"
                        >Click here to learn more</a
                    >.
                </p>
            </section>
        </div>
    </div>

    <div
        class="mt-10 border-t border-gray-200 px-4 py-4 pt-6 text-center text-sm text-gray-500 md:mt-12 md:px-0"
    >
        <p>© {year} Andrew For Council. All rights reserved.</p>

        <p class="mt-2">
            Website developed and maintained by <u>Wesley King</u>
        </p>
    </div>
</footer>
