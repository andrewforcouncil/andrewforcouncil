---
import "../styles/global.css";
---

<div
    class="relative flex w-screen items-center justify-center overflow-hidden py-3"
>
    <!-- Background image -->
    <img
        src="/UniversityAve.webp"
        alt=""
        class="absolute inset-0 h-fit w-full object-cover -z-10"
    />

    <!-- Optional dark overlay -->
    <div class="absolute inset-0 bg-black/40 -z-10"></div>

    <!-- YouTube embed -->
    <iframe
        class="aspect-video w-full max-w-5xl rounded-xl shadow-xl"
        src="https://www.youtube.com/embed/iYlODtkyw_I"
        title="YouTube video player"
        allowfullscreen></iframe>
</div>
