---
import "../styles/global.css";

interface Props {
    title?: string;
    target: string; // ISO date
}

const { title = "Time Remaining", target } = Astro.props;
---

<section>
    <div class="bg-section py-6">
        <div
            class="mx-auto flex max-w-6xl items-center justify-between px-4 md:px-6"
        >
            <div class="h-px min-w-0 flex-1 bg-gray-600"></div>

            <div class="mx-2 min-w-0 text-center sm:mx-4 md:mx-8">
                <h2 class="text-lg font-bold text-almond md:text-xl">
                    {title}
                </h2>
                <p
                    id="countdown"
                    data-target={target}
                    class="whitespace-nowrap font-mono text-xl text-cool-orange sm:text-2xl md:text-3xl"
                >
                    Loading...
                </p>
            </div>

            <div class="h-px min-w-0 flex-1 bg-gray-600"></div>
        </div>
    </div>

    <script>
        const countdown = document.getElementById("countdown");

        if (countdown) {
            const target = new Date(countdown.dataset.target);

            function update() {
                const now = new Date();
                const diff = target - now;

                if (diff <= 0) {
                    countdown.textContent = "00:00:00";
                    return;
                }

                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor(diff / (1000 * 60 * 60)) % 24;
                const minutes = Math.floor(diff / (1000 * 60)) % 60;
                const seconds = Math.floor(diff / 1000) % 60;

                countdown.textContent = `${days}d ${hours}h ${minutes}m ${seconds}s`;
            }

            update();
            setInterval(update, 1000);
        }
    </script>
</section>
